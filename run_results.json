{"metadata": {"dbt_schema_version": "https://schemas.getdbt.com/dbt/run-results/v6.json", "dbt_version": "1.11.7", "generated_at": "2026-04-04T05:10:28.789204Z", "invocation_id": "4a84f089-244a-4ea1-a6a8-39c2a4ed39b3", "invocation_started_at": "2026-04-04T05:10:24.364641Z", "env": {}}, "results": [{"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-04T05:10:28.519611Z", "completed_at": "2026-04-04T05:10:28.527152Z"}, {"name": "execute", "started_at": "2026-04-04T05:10:28.527631Z", "completed_at": "2026-04-04T05:10:28.527647Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.009124040603637695, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.plant_sensor_dbt.vw_leituras_silver", "compiled": true, "compiled_code": "\n\nSELECT \n    id,\n    -- Converte o hor\u00e1rio para SP e salva como timestamp limpo (sem fuso)\n    data_ingestao AT TIME ZONE 'America/Sao_Paulo' AS data_leitura_sp,\n    \n    -- Extrai as chaves do JSON e j\u00e1 converte para o tipo correto (N\u00famero)\n    (dados_json->>'temperature_c')::NUMERIC AS temperatura_c,\n    (dados_json->>'humidity_pct')::NUMERIC AS umidade_ar_pct,\n    (dados_json->>'soil_moisture_raw')::INT AS umidade_solo_raw,\n    (dados_json->>'light_intensity_raw')::NUMERIC AS luz_raw,\n    \n    arquivo_origem AS dispositivo\nFROM \n    \"postgres\".\"public\".\"leituras_brutas_bronze\"", "relation_name": "\"postgres\".\"public\".\"vw_leituras_silver\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-04T05:10:28.530039Z", "completed_at": "2026-04-04T05:10:28.531564Z"}, {"name": "execute", "started_at": "2026-04-04T05:10:28.532065Z", "completed_at": "2026-04-04T05:10:28.532077Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.0033261775970458984, "adapter_response": {}, "message": null, "failures": null, "unique_id": "seed.plant_sensor_dbt.cadastro_sensores", "compiled": null, "compiled_code": null, "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-04T05:10:28.534231Z", "completed_at": "2026-04-04T05:10:28.535668Z"}, {"name": "execute", "started_at": "2026-04-04T05:10:28.536106Z", "completed_at": "2026-04-04T05:10:28.536114Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.002863168716430664, "adapter_response": {}, "message": null, "failures": null, "unique_id": "seed.plant_sensor_dbt.limites_plantas_cientifico", "compiled": null, "compiled_code": null, "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-04T05:10:28.538263Z", "completed_at": "2026-04-04T05:10:28.550886Z"}, {"name": "execute", "started_at": "2026-04-04T05:10:28.551356Z", "completed_at": "2026-04-04T05:10:28.551373Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.014240026473999023, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.plant_sensor_dbt.not_null_vw_leituras_silver_data_leitura_sp.98169cdcfe", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect data_leitura_sp\nfrom \"postgres\".\"public\".\"vw_leituras_silver\"\nwhere data_leitura_sp is null\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-04T05:10:28.553466Z", "completed_at": "2026-04-04T05:10:28.557949Z"}, {"name": "execute", "started_at": "2026-04-04T05:10:28.558381Z", "completed_at": "2026-04-04T05:10:28.558392Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.005896329879760742, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.plant_sensor_dbt.not_null_vw_leituras_silver_dispositivo.1fc45f5233", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect dispositivo\nfrom \"postgres\".\"public\".\"vw_leituras_silver\"\nwhere dispositivo is null\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-04T05:10:28.560390Z", "completed_at": "2026-04-04T05:10:28.564537Z"}, {"name": "execute", "started_at": "2026-04-04T05:10:28.564967Z", "completed_at": "2026-04-04T05:10:28.564977Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.005513191223144531, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.plant_sensor_dbt.not_null_vw_leituras_silver_id.beb8b21aae", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect id\nfrom \"postgres\".\"public\".\"vw_leituras_silver\"\nwhere id is null\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-04T05:10:28.566949Z", "completed_at": "2026-04-04T05:10:28.570918Z"}, {"name": "execute", "started_at": "2026-04-04T05:10:28.571336Z", "completed_at": "2026-04-04T05:10:28.571344Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.005337715148925781, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.plant_sensor_dbt.not_null_vw_leituras_silver_temperatura_c.9e8c77dfd2", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect temperatura_c\nfrom \"postgres\".\"public\".\"vw_leituras_silver\"\nwhere temperatura_c is null\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-04T05:10:28.573333Z", "completed_at": "2026-04-04T05:10:28.577306Z"}, {"name": "execute", "started_at": "2026-04-04T05:10:28.577749Z", "completed_at": "2026-04-04T05:10:28.577758Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.005438089370727539, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.plant_sensor_dbt.not_null_vw_leituras_silver_umidade_ar_pct.1bcb969099", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect umidade_ar_pct\nfrom \"postgres\".\"public\".\"vw_leituras_silver\"\nwhere umidade_ar_pct is null\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-04T05:10:28.579723Z", "completed_at": "2026-04-04T05:10:28.583680Z"}, {"name": "execute", "started_at": "2026-04-04T05:10:28.584103Z", "completed_at": "2026-04-04T05:10:28.584111Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.005390167236328125, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.plant_sensor_dbt.not_null_vw_leituras_silver_umidade_solo_raw.397445d9a2", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect umidade_solo_raw\nfrom \"postgres\".\"public\".\"vw_leituras_silver\"\nwhere umidade_solo_raw is null\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-04T05:10:28.586045Z", "completed_at": "2026-04-04T05:10:28.592017Z"}, {"name": "execute", "started_at": "2026-04-04T05:10:28.592446Z", "completed_at": "2026-04-04T05:10:28.592453Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.0074117183685302734, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.plant_sensor_dbt.unique_vw_leituras_silver_id.5116beb0cb", "compiled": true, "compiled_code": "\n    \n    \n\nselect\n    id as unique_field,\n    count(*) as n_records\n\nfrom \"postgres\".\"public\".\"vw_leituras_silver\"\nwhere id is not null\ngroup by id\nhaving count(*) > 1\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-04T05:10:28.594398Z", "completed_at": "2026-04-04T05:10:28.598384Z"}, {"name": "execute", "started_at": "2026-04-04T05:10:28.598836Z", "completed_at": "2026-04-04T05:10:28.598843Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.005392551422119141, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.plant_sensor_dbt.not_null_cadastro_sensores_dispositivo.ced6778366", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect dispositivo\nfrom \"postgres\".\"public\".\"cadastro_sensores\"\nwhere dispositivo is null\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-04T05:10:28.600803Z", "completed_at": "2026-04-04T05:10:28.604679Z"}, {"name": "execute", "started_at": "2026-04-04T05:10:28.605103Z", "completed_at": "2026-04-04T05:10:28.605110Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.005293607711791992, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.plant_sensor_dbt.not_null_cadastro_sensores_nome_planta.8d1ec01b67", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect nome_planta\nfrom \"postgres\".\"public\".\"cadastro_sensores\"\nwhere nome_planta is null\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-04T05:10:28.607013Z", "completed_at": "2026-04-04T05:10:28.610853Z"}, {"name": "execute", "started_at": "2026-04-04T05:10:28.611267Z", "completed_at": "2026-04-04T05:10:28.611273Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.005212545394897461, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.plant_sensor_dbt.unique_cadastro_sensores_dispositivo.ab37e66ec1", "compiled": true, "compiled_code": "\n    \n    \n\nselect\n    dispositivo as unique_field,\n    count(*) as n_records\n\nfrom \"postgres\".\"public\".\"cadastro_sensores\"\nwhere dispositivo is not null\ngroup by dispositivo\nhaving count(*) > 1\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-04T05:10:28.613214Z", "completed_at": "2026-04-04T05:10:28.618686Z"}, {"name": "execute", "started_at": "2026-04-04T05:10:28.619118Z", "completed_at": "2026-04-04T05:10:28.619125Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.006884574890136719, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.plant_sensor_dbt.gold_diaria_monitorizacao", "compiled": true, "compiled_code": "\n\n-- Esta consulta tem como objetivo criar uma vis\u00e3o di\u00e1ria de monitoramento das condi\u00e7\u00f5es ambientais para as plantas, com foco na sa\u00fade luminosa.\n-- Ela agrega as leituras de temperatura, umidade e luz, calcula o tempo de exposi\u00e7\u00e3o \u00e0 luz e escurid\u00e3o, e compara com as metas definidas para cada planta, \n-- al\u00e9m de avaliar a cobertura dos dados para garantir an\u00e1lises confi\u00e1veis.\nWITH leituras_com_lag AS (\n    SELECT \n        l.data_leitura_sp,\n        DATE(l.data_leitura_sp) AS data_ref,\n        l.temperatura_c,\n        l.umidade_ar_pct,\n        l.luz_raw AS luz_lux,\n        (l.luz_raw * 0.0185) AS luz_par_ppfd, -- Convers\u00e3o aproximada de lux para PPFD, da luz vis\u00edvel par a luz que as plantas usam para fotoss\u00edntese\n        p.lux_min,\n        p.horas_luz_minimas,\n        p.horas_descanso_minimas,\n        ((3050 - l.umidade_solo_raw) / (3050 - 600.0)) * 100 AS umidade_solo_pct,\n        \n        -- Calcula o intervalo bruto em minutos desde a \u00faltima leitura\n        EXTRACT(EPOCH FROM (l.data_leitura_sp - LAG(l.data_leitura_sp) OVER (PARTITION BY DATE(l.data_leitura_sp) ORDER BY l.data_leitura_sp))) / 60.0 AS delta_minutos\n\n    FROM \"postgres\".\"public\".\"vw_leituras_silver\" l\n    JOIN \"postgres\".\"public\".\"cadastro_sensores\" c ON l.dispositivo = c.dispositivo\n    JOIN \"postgres\".\"public\".\"limites_plantas_cientifico\" p ON c.nome_planta = p.nome_popular\n),\n\n-- Enriquecemos as leituras com o tratamento de gaps para garantir que per\u00edodos sem dados n\u00e3o distor\u00e7am as an\u00e1lises di\u00e1rias\nleituras_enriquecidas AS (\n    SELECT \n        *,\n        -- \ud83d\udee1\ufe0f TRATAMENTO DE GAPS (BURACOS DE TEMPO)\n        CASE \n            WHEN delta_minutos IS NULL THEN 15.0 -- Primeira leitura do dia assumimos 15 minutos de monitoramento antes da leitura\n            WHEN delta_minutos > 60.0 THEN 15.0  -- Sensor ficou offline e voltou, n\u00e3o contamos as horas perdidas\n            ELSE delta_minutos                   -- Funcionamento normal cont\u00ednuo\n        END AS minutos_desde_ultima_leitura\n    FROM leituras_com_lag\n),\n\n-- Agregamos as leituras por dia para calcular as m\u00e9dias e totais di\u00e1rios, al\u00e9m de comparar com as metas de luz e descanso\nagregacao_diaria AS (\n    SELECT \n        data_ref,\n        AVG(temperatura_c) AS temp_media,\n        AVG(umidade_ar_pct) AS umid_media,\n        AVG(luz_par_ppfd) AS par_ppfd_medio,\n        \n        SUM(minutos_desde_ultima_leitura) AS total_minutos_monitorados,\n        AVG(umidade_solo_pct) AS umid_solo_media,\n\n        -- Calculamos o tempo total de exposi\u00e7\u00e3o \u00e0 luz e escurid\u00e3o com base no limiar de 50 lux dividindo o dia em per\u00edodos de luz e escurid\u00e3o\n        SUM(CASE WHEN luz_lux >= 50 THEN minutos_desde_ultima_leitura ELSE 0 END) / 60.0 AS horas_sol_util,\n        SUM(CASE WHEN luz_lux < 50 THEN minutos_desde_ultima_leitura ELSE 0 END) / 60.0 AS horas_escuridao,\n        \n        MAX(horas_luz_minimas) AS meta_luz,\n        MAX(horas_descanso_minimas) AS meta_descanso\n    FROM leituras_enriquecidas\n    GROUP BY data_ref\n)\n\n-- Na tabela final, calculamos a taxa de cobertura dos dados e aplicamos as regras de alerta para sa\u00fade luminosa\nSELECT \n    data_ref,\n    ROUND(temp_media, 1) AS temperatura_media_c,\n    ROUND(umid_media, 1) AS umidade_media_pct,\n    ROUND(par_ppfd_medio, 2) AS par_ppfd_medio,\n    ROUND(horas_sol_util, 2) AS horas_sol_util_diarias,\n    ROUND(horas_escuridao, 2) AS horas_descanso_diarias,\n    ROUND(umid_solo_media, 1) AS umidade_solo_media_pct,\n    \n    -- Limitamos a 100% para evitar flutua\u00e7\u00f5es decimais (ex: 100.3%)\n    LEAST(ROUND((total_minutos_monitorados / 1440.0) * 100, 1), 100.0) AS taxa_cobertura_dados_pct,\n    \n    CASE \n        WHEN (total_minutos_monitorados / 1440.0) < 0.70 THEN 'ALERTA: Dados Insuficientes (< 70% Uptime)'\n        WHEN horas_sol_util < meta_luz THEN 'ALERTA: D\u00e9ficit de Luz'\n        WHEN horas_escuridao < meta_descanso THEN 'ALERTA: Stress Luminoso (Falta Descanso)'\n        ELSE 'Luminosidade e Fotoper\u00edodo Adequados'\n    END AS status_saude_luminosa\n\nFROM agregacao_diaria\nORDER BY data_ref DESC", "relation_name": "\"postgres\".\"public\".\"gold_diaria_monitorizacao\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-04T05:10:28.621467Z", "completed_at": "2026-04-04T05:10:28.624906Z"}, {"name": "execute", "started_at": "2026-04-04T05:10:28.625317Z", "completed_at": "2026-04-04T05:10:28.625323Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.005221366882324219, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.plant_sensor_dbt.gold_granulada_monitorizacao", "compiled": true, "compiled_code": "\n\nWITH leituras AS (\n    SELECT * FROM \"postgres\".\"public\".\"vw_leituras_silver\"\n),\n\n-- Nova CTE puxando o nosso Seed (A Tabela de De/Para)\ncadastro_sensores AS (\n    SELECT * FROM \"postgres\".\"public\".\"cadastro_sensores\"\n),\n\nlimites_cientificos AS (\n    SELECT * FROM \"postgres\".\"public\".\"limites_plantas_cientifico\"\n),\n\n-- Na CTE de cruzamento, juntamos as leituras com o cadastro de sensores para descobrir qual planta est\u00e1 sendo monitorizada, \n--e depois juntamos com os limites cient\u00edficos para obter as metas de temperatura, umidade e luz para cada planta.\ncruzamento AS (\n    SELECT \n        l.id,\n        l.data_leitura_sp,\n        l.temperatura_c,\n        l.umidade_ar_pct,    \n        l.umidade_solo_raw,\n\n        -- Regra de tr\u00eas invertida: 3050 (0%) a 600 (100%)\n        -- Usamos GREATEST e LEAST para travar o valor entre 0 e 100 (evitar -5% ou 110%)\n        GREATEST(0, LEAST(100, ROUND(((3050 - l.umidade_solo_raw) / (3050 - 600.0)) * 100, 1))) AS umidade_solo_pct,\n\n        -- A luz instant\u00e2nea para o gr\u00e1fico de linhas do Power BI\n        l.luz_raw,\n        ROUND((l.luz_raw * 0.0185), 2) AS luz_par_ppfd,\n\n        c.nome_popular AS planta_monitorizada,\n        c.nome_cientifico,\n        c.temp_min_c,\n        c.temp_max_c,\n        c.umid_ar_min_pct,\n        c.umid_ar_max_pct,\n        c.tolerancia_seca,\n        TRUE AS flg_origem_dados_confiavel \n    FROM leituras l\n    \n    -- 1\u00ba JOIN: Descobre a planta com base no MAC Address / Dispositivo\n    LEFT JOIN cadastro_sensores cs \n        ON l.dispositivo = cs.dispositivo\n        \n    -- 2\u00ba JOIN: Busca os limites biol\u00f3gicos da planta que acabamos de descobrir\n    LEFT JOIN limites_cientificos c \n        ON cs.nome_planta = c.nome_popular\n)\n\n-- Na tabela final, aplicamos as regras de alerta para cada par\u00e2metro ambiental, comparando as leituras com os limites cient\u00edficos para cada planta monitorizada.\nSELECT \n    *,\n    -- 1. Temperatura\n    CASE \n        WHEN temperatura_c < temp_min_c THEN 'ALERTA: Frio extremo'\n        WHEN temperatura_c > temp_max_c THEN 'ALERTA: Calor extremo'\n        ELSE 'Temperatura Ideal'\n    END AS status_temperatura,\n    \n    -- 2. Umidade do Ar\n    CASE \n        WHEN umidade_ar_pct < umid_ar_min_pct THEN 'ALERTA: Ar muito seco'\n        WHEN umidade_ar_pct > umid_ar_max_pct THEN 'ALERTA: Ar muito \u00famido'\n        ELSE 'Umidade do Ar Adequada'\n    END AS status_umidade_ar,\n\n    -- 3. Umidade do Solo\n    CASE \n        WHEN tolerancia_seca = 'ALTA'  AND umidade_solo_pct <= 20 THEN 'ALERTA: Solo Seco (Regar)'\n        WHEN tolerancia_seca = 'MEDIA' AND umidade_solo_pct <= 40 THEN 'ALERTA: Solo Seco (Regar)'\n        WHEN tolerancia_seca = 'BAIXA' AND umidade_solo_pct <= 60 THEN 'ALERTA: Solo Seco (Regar)'\n        ELSE 'Umidade do Solo Adequada'\n    END AS status_umidade_solo\n\nFROM cruzamento", "relation_name": "\"postgres\".\"public\".\"gold_granulada_monitorizacao\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-04T05:10:28.627564Z", "completed_at": "2026-04-04T05:10:28.631402Z"}, {"name": "execute", "started_at": "2026-04-04T05:10:28.631847Z", "completed_at": "2026-04-04T05:10:28.631854Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.005567312240600586, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.plant_sensor_dbt.not_null_gold_diaria_monitorizacao_data_ref.4be4ce184e", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect data_ref\nfrom \"postgres\".\"public\".\"gold_diaria_monitorizacao\"\nwhere data_ref is null\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-04T05:10:28.633821Z", "completed_at": "2026-04-04T05:10:28.637656Z"}, {"name": "execute", "started_at": "2026-04-04T05:10:28.638078Z", "completed_at": "2026-04-04T05:10:28.638085Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.005266904830932617, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.plant_sensor_dbt.not_null_gold_diaria_monitorizacao_horas_descanso_diarias.5aec0e5b57", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect horas_descanso_diarias\nfrom \"postgres\".\"public\".\"gold_diaria_monitorizacao\"\nwhere horas_descanso_diarias is null\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-04T05:10:28.640090Z", "completed_at": "2026-04-04T05:10:28.644106Z"}, {"name": "execute", "started_at": "2026-04-04T05:10:28.644542Z", "completed_at": "2026-04-04T05:10:28.644549Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.005491495132446289, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.plant_sensor_dbt.not_null_gold_di