{"metadata": {"dbt_schema_version": "https://schemas.getdbt.com/dbt/run-results/v6.json", "dbt_version": "1.11.7", "generated_at": "2026-04-04T05:29:49.337305Z", "invocation_id": "b8aa5367-6f06-4cf5-899f-c4456551fa5d", "invocation_started_at": "2026-04-04T05:29:44.334682Z", "env": {}}, "results": [{"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-04T05:29:49.049386Z", "completed_at": "2026-04-04T05:29:49.057751Z"}, {"name": "execute", "started_at": "2026-04-04T05:29:49.058282Z", "completed_at": "2026-04-04T05:29:49.058299Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.010071039199829102, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.plant_sensor_dbt.vw_leituras_silver", "compiled": true, "compiled_code": "\n\nSELECT \n    id,\n    -- Converte o hor\u00e1rio para SP e salva como timestamp limpo (sem fuso)\n    data_ingestao AT TIME ZONE 'America/Sao_Paulo' AS data_leitura_sp,\n    \n    -- Extrai as chaves do JSON e j\u00e1 converte para o tipo correto (N\u00famero)\n    (dados_json->>'temperature_c')::NUMERIC AS temperatura_c,\n    (dados_json->>'humidity_pct')::NUMERIC AS umidade_ar_pct,\n    (dados_json->>'soil_moisture_raw')::INT AS umidade_solo_raw,\n    (dados_json->>'light_intensity_raw')::NUMERIC AS luz_raw,\n    \n    arquivo_origem AS dispositivo\nFROM \n    \"postgres\".\"public\".\"leituras_brutas_bronze\"", "relation_name": "\"postgres\".\"public\".\"vw_leituras_silver\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-04T05:29:49.060954Z", "completed_at": "2026-04-04T05:29:49.062579Z"}, {"name": "execute", "started_at": "2026-04-04T05:29:49.063096Z", "completed_at": "2026-04-04T05:29:49.063109Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.0032901763916015625, "adapter_response": {}, "message": null, "failures": null, "unique_id": "seed.plant_sensor_dbt.cadastro_sensores", "compiled": null, "compiled_code": null, "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-04T05:29:49.065701Z", "completed_at": "2026-04-04T05:29:49.067241Z"}, {"name": "execute", "started_at": "2026-04-04T05:29:49.067705Z", "completed_at": "2026-04-04T05:29:49.067715Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.0031638145446777344, "adapter_response": {}, "message": null, "failures": null, "unique_id": "seed.plant_sensor_dbt.limites_plantas_cientifico", "compiled": null, "compiled_code": null, "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-04T05:29:49.070083Z", "completed_at": "2026-04-04T05:29:49.082901Z"}, {"name": "execute", "started_at": "2026-04-04T05:29:49.083404Z", "completed_at": "2026-04-04T05:29:49.083417Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.014514923095703125, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.plant_sensor_dbt.not_null_vw_leituras_silver_data_leitura_sp.98169cdcfe", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect data_leitura_sp\nfrom \"postgres\".\"public\".\"vw_leituras_silver\"\nwhere data_leitura_sp is null\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-04T05:29:49.085651Z", "completed_at": "2026-04-04T05:29:49.089667Z"}, {"name": "execute", "started_at": "2026-04-04T05:29:49.090152Z", "completed_at": "2026-04-04T05:29:49.090161Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.0056111812591552734, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.plant_sensor_dbt.not_null_vw_leituras_silver_dispositivo.1fc45f5233", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect dispositivo\nfrom \"postgres\".\"public\".\"vw_leituras_silver\"\nwhere dispositivo is null\n\n\n", "relation_name": null, "batch_results": null}, {"status": "suc