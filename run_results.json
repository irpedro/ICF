{"metadata": {"dbt_schema_version": "https://schemas.getdbt.com/dbt/run-results/v6.json", "dbt_version": "1.11.7", "generated_at": "2026-04-04T05:14:57.665469Z", "invocation_id": "ca361777-77d4-414f-a94a-610067460817", "invocation_started_at": "2026-04-04T05:14:52.374647Z", "env": {}}, "results": [{"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-04T05:14:57.392671Z", "completed_at": "2026-04-04T05:14:57.400743Z"}, {"name": "execute", "started_at": "2026-04-04T05:14:57.401216Z", "completed_at": "2026-04-04T05:14:57.401232Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.009662866592407227, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.plant_sensor_dbt.vw_leituras_silver", "compiled": true, "compiled_code": "\n\nSELECT \n    id,\n    -- Converte o hor\u00e1rio para SP e salva como timestamp limpo (sem fuso)\n    data_ingestao AT TIME ZONE 'America/Sao_Paulo' AS data_leitura_sp,\n    \n    -- Extrai as chaves do JSON e j\u00e1 converte para o tipo correto (N\u00famero)\n    (dados_json->>'temperature_c')::NUMERIC AS temperatura_c,\n    (dados_json->>'humidity_pct')::NUMERIC AS umidade_ar_pct,\n    (dados_json->>'soil_moisture_raw')::INT AS umidade_solo_raw,\n    (dados_json->>'light_intensity_raw')::NUMERIC AS luz_raw,\n    \n    arquivo_origem AS dispositivo\nFROM \n    \"postgres\".\"public\".\"leituras_brutas_bronze\"", "relation_name": "\"postgres\".\"public\".\"vw_leituras_silver\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-04T05:14:57.403808Z", "completed_at": "2026-04-04T05:14:57.405895Z"}, {"name": "execute", "started_at": "2026-04-04T05:14:57.406378Z", "completed_at": "2026-04-04T05:14:57.406388Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.0038573741912841797, "adapter_response": {}, "message": null, "failures": null, "unique_id": "seed.plant_sensor_dbt.cadastro_sensores", "compiled": null, "compiled_code": null, "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-04T05:14:57.408721Z", "completed_at": "2026-04-04T05:14:57.409976Z"}, {"name": "execute", "started_at": "2026-04-04T05:14:57.410447Z", "completed_at": "2026-04-04T05:14:57.410457Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.002910614013671875, "adapter_response": {}, "message": null, "failures": null, "unique_id": "seed.plant_sensor_dbt.limites_plantas_cientifico", "compiled": null, "compiled_code": null, "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-04T05:14:57.412735Z", "completed_at": "2026-04-04T05:14:57.424050Z"}, {"name": "execute", "started_at": "2026-04-04T05:14:57.424543Z", "completed_at": "2026-04-04T05:14:57.424554Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.012883901596069336, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.plant_sensor_dbt.not_null_vw_leituras_silver_data_leitura_sp.98169cdcfe", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect data_leitura_sp\nfrom \"postgres\".\"public\".\"vw_leituras_silver\"\nwhere data_leitura_sp is null\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-04T05:14:57.426733Z", "completed_at": "2026-04-04T05:14:57.430590Z"}, {"name": "execute", "started_at": "2026-04-04T05:14:57.431039Z", "completed_at": "2026-04-04T05:14:57.431047Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.005342721939086914, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.plant_sensor_dbt.not_null_vw_leituras_silver_dispositivo.1fc45f5233", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect dispositivo\nfrom \"postgres\".\"public\".\"vw_leituras_silver\"\nwhere dispositivo is null\n\n\n", "relation_name": null, "batch_results": null}, {"status": "succe